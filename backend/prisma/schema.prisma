generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)
  jobs     Job[]

  createdAt DateTime @default(now())
}

model Job {
  id String @id @default(cuid())

  title String

  description String?

  payload Json?

  status JobStatus @default(PENDING)

  priority JobPriority @default(MEDIUM)

  delay Int @default(0)

  createdAt DateTime @default(now())

  startedAt DateTime?

  completedAt DateTime?

  userId String

  user User @relation(fields: [userId], references: [id])

  image String

  processingStage String @default("Queued")

  progress Int @default(0)

  workerName String?
  logs       JobLog[]
}

model JobLog {
  id String @id @default(cuid())

  message String

  createdAt DateTime @default(now())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
